# API key for model provider used by Mastra agents/workflows.
OPENAI_API_KEY=your-api-key

# Workspace-relative path to the JSON document used as workflow input.
ENTITY_EXTRACTION_DOC_PATH=src/docs/2025 Australian Cotton Production Manual_interactive_sml.json

# Max heading length treated as weak/noisy (weak headings do not force a split).
ENTITY_EXTRACTION_WEAK_HEADING_MAX_LENGTH=3

# Minimum buffered chunk size (characters) before a strong heading can trigger a split.
ENTITY_EXTRACTION_MIN_CHUNK_SIZE_CHARS=450

# Minimum number of alphabetic words required for a chunk to be kept.
ENTITY_EXTRACTION_MIN_CHUNK_ALPHA_WORDS=10

# Minimum ratio of alphabetic characters to all non-whitespace characters.
ENTITY_EXTRACTION_MIN_CHUNK_ALPHA_RATIO=0.35
