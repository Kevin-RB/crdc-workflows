# API key for model provider used by Mastra agents/workflows.
OPENAI_API_KEY=your-api-key

# Workspace-relative path to the JSON document used as workflow input.
ENTITY_EXTRACTION_DOC_PATH=src/docs/2025 Australian Cotton Production Manual_interactive_sml.json

# Relative file path to the dummy JSON used for testing the workflow with a fixed input.
DUMMY_JSON_RELATIVE_FILE_PATH=your-relative-path-to-dummy-json.json

# Max heading length treated as weak/noisy (weak headings do not force a split).
ENTITY_EXTRACTION_WEAK_HEADING_MAX_LENGTH=3

# Minimum buffered chunk size (characters) before a strong heading can trigger a split.
ENTITY_EXTRACTION_MIN_CHUNK_SIZE_CHARS=450

# Minimum number of alphabetic words required for a chunk to be kept.
ENTITY_EXTRACTION_MIN_CHUNK_ALPHA_WORDS=10

# Minimum ratio of alphabetic characters to all non-whitespace characters.
ENTITY_EXTRACTION_MIN_CHUNK_ALPHA_RATIO=0.35

# Maximum chunk size before section content is recursively split.
ENTITY_EXTRACTION_MAX_CHUNK_SIZE_CHARS=3500

# Character overlap used when recursively splitting oversized section content.
ENTITY_EXTRACTION_CHUNK_OVERLAP_CHARS=300

# Similarity threshold used for same-type fuzzy entity deduplication (0 to 1).
ENTITY_EXTRACTION_ENTITY_MATCH_THRESHOLD=0.88

# LMstudio API key for testing with LMStudio-hosted models.
LMSTUDIO_API_KEY=your-lmstudio-api-key

# Where the global state for entity extraction is persisted (relative to project root).
ENTITY_EXTRACTION_STATE_RELATIVE_FILE_PATH=src/docs/entity-extraction/global-state.json

# Neo4j connection details for graph database integration.
NEO4J_URI=neo4j+s://your-neo4j-uri

# Neo4j credentials for authentication.
NEO4J_USERNAME=your-neo4j-username

# Neo4j database name for storing extracted entities and relationships.
NEO4J_PASSWORD=your-neo4j-password

# Neo4j Aura instance details for cloud-hosted graph database service.
NEO4J_DATABASE=your-neo4j-database

# Neo4j Aura instance ID for connecting to the correct graph database instance.
AURA_INSTANCEID=your-aura-instance-id

# Neo4j Aura instance name for easier identification in the Neo4j Aura dashboard. 
AURA_INSTANCENAME=your-aura-instance-name